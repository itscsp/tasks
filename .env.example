# Copy this to .env on your server and set these values

# The port Hostinger assigns to your Node.js app
# Find it in hPanel > Node.js > Application Port
PORT=3000

# Must be 'production' on the live server
NODE_ENV=production

# Random secret to protect the deploy webhook endpoint
# Generate one with: openssl rand -hex 32
DEPLOY_SECRET=your-random-secret-here
